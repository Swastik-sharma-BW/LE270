#####
##FIBOCOM_BASE
ifneq ($(wildcard target.inc),)
include $(TOP)/project/$(AVAILABLE_TARGETS)/ap/apps/bootloader/GCC/target.inc
endif

FIBOCOM_BL_CTR = y

ifeq ($(FIBOCOM_OPENCPU),y)
CFLAGS += -DFIBOCOM_OPENCPU -DFOTA_PRESET_RAM_ENABLE=1
endif

ifeq ($(CONFIG_ECM_ECMMODE_DEFAULT),y)
CFLAGS += -DCONFIG_ECM_ECMMODE_DEFAULT
endif


ifeq ($(FFW_FLYMODEM_CONFIG),y)
CFLAGS += -DCONFIG_FLYMODEM_BL_LED
endif


ifeq ($(FFW_NEWLAND_CONFIG),y)
CFLAGS += -DFFW_NEWLAND_CONFIG
endif

ifeq ($(CONFIG_FFW_TWO_BOOTLOADER),y)
CFLAGS += -DCONFIG_FFW_TWO_BOOTLOADER
CFLAGS_DEFS += -DCONFIG_FFW_TWO_BOOTLOADER
endif

ifeq ($(CONFIG_FFW_UART_LOG_CLOSE), y)
CFLAGS += -DCONFIG_FFW_UART_LOG_CLOSE
endif

ifeq ($(FFW_XINYUAN_CONFIG), y)
CFLAGS += -DFFW_XINYUAN_CONFIG
endif

ifeq ($(CONFIG_FIBO_FEATURE_BOOTFOTA_HLS), y)
MIDDLEWARE_FOTA_HLS_ENABLE = y
endif

ifeq ($(CONFIG_QFOTADL_EXTEND_ENABLE), y)
CFLAGS += -DCONFIG_QFOTADL_EXTEND_ENABLE
endif

ifeq ($(CONFIG_FFW_FEATURE_SUPPORT_POSIX_API), y)
CFLAGS += -DCONFIG_FFW_FEATURE_SUPPORT_POSIX_API
endif

ifeq ($(CONFIG_CUST_KR_FEATURE), y)
CFLAGS += -DCONFIG_CUST_KR_FEATURE
endif

ifeq ($(CONFIG_FFW_FEATURE_DEFAULT_DEBUG_UART_LOG), y)
CFLAGS += -DCONFIG_FFW_FEATURE_DEFAULT_DEBUG_UART_LOG
endif

ifeq ($(CONFIG_FFW_FEATURE_DEBUG_UART_LOG_BAUD_6M), y)
CFLAGS += -DCONFIG_FFW_FEATURE_DEBUG_UART_LOG_BAUD_6M
endif

CFLAGS += -DCONFIG_FIBO_VERIFY_SIGNATURE

ifeq ($(CONFIG_FFW_FEATURE_SECBOOT), y)
CFLAGS += -DCONFIG_PROJ_APP_SECURITY_BOOT
CFLAGS += -DCONFIG_FFW_FEATURE_SECBOOT
endif

ifeq ($(CONFIG_CUST_YINGSHI_FEATURE), y)
CFLAGS += -DCONFIG_CUST_YINGSHI_FEATURE
endif

ifeq ($(CONFIG_FFW_FEATURE_USBPOWERON), y)
CFLAGS += -DCONFIG_FFW_FEATURE_USBPOWERON
endif